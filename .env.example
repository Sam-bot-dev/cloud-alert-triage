# Required — used as API key for LLM calls (primary auth variable)
HF_TOKEN=hf_...

# Optional — defaults are provided in inference.py
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# Optional — alternative API keys (inference.py checks all three)
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Optional — URL of the running environment server
ENV_URL=http://localhost:7860
